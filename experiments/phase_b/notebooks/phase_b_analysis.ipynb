   "source": [
    "# Phase B — Post-Hoc Analysis\n",
    "## Step 1: LN Scaling Law Validation (Phase B1, 8 runs × 200 epochs)\n",
    "\n",
    "From Kaggle output:\n",
    "| D | seed | loss | acc |\n",
    "|---|------|------|-----|\n",
    "| 32 | 42 | 1.0958 | 0.6251 |\n",
    "| 32 | 123 | 1.1056 | 0.6150 |\n",
    "| 48 | 42 | 1.0212 | 0.6504 |\n",
    "| 48 | 123 | 1.0274 | 0.6477 |\n",
    "| 64 | 42 | 0.9626 | 0.6683 |\n",
    "| 64 | 123 | 0.9757 | 0.6668 |\n",
    "| 96 | 42 | 0.9035 | 0.6929 |\n",
    "| 96 | 123 | 0.9045 | 0.6878 |"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "import numpy as np\n",
    "from scipy.optimize import curve_fit\n",
    "from scipy.stats import spearmanr, pearsonr\n",
    "import matplotlib.pyplot as plt\n",
    "import json\n",
    "\n",
    "# LN validation data (Phase B1, LayerNorm, depth=3, skip=False)\n",
    "ln_data = [\n",
    "    {\"D\": 32, \"seed\": 42,  \"loss\": 1.0958, \"acc\": 0.6251},\n",
    "    {\"D\": 32, \"seed\": 123, \"loss\": 1.1056, \"acc\": 0.6150},\n",
    "    {\"D\": 48, \"seed\": 42,  \"loss\": 1.0212, \"acc\": 0.6504},\n",
    "    {\"D\": 48, \"seed\": 123, \"loss\": 1.0274, \"acc\": 0.6477},\n",
    "    {\"D\": 64, \"seed\": 42,  \"loss\": 0.9626, \"acc\": 0.6683},\n",
    "    {\"D\": 64, \"seed\": 123, \"loss\": 0.9757, \"acc\": 0.6668},\n",
    "    {\"D\": 96, \"seed\": 42,  \"loss\": 0.9035, \"acc\": 0.6929},\n",
    "    {\"D\": 96, \"seed\": 123, \"loss\": 0.9045, \"acc\": 0.6878},\n",
    "]\n",
    "\n",
    "# Average over seeds\n",
    "loss_by_D = {}\n",
    "for r in ln_data:\n",
    "    D = r[\"D\"]\n",
    "    loss_by_D.setdefault(D, []).append(r[\"loss\"])\n",
    "Ds = np.array(list(loss_by_D.keys()))\n",
    "Ls = np.array([np.mean(loss_by_D[d]) for d in Ds])\n",
    "\n",
    "# Power law fit: L(D) = a * D^(-b) + c\n",
    "def plaw(D, a, b, c): return a * D**(-b) + c\n",
    "popt, pcov = curve_fit(plaw, Ds, Ls, p0=[10, 0.5, 0.5],\n",
    "                         bounds=([0,0,0],[1000,3,3]), maxfev=10000)\n",
    "a, beta_LN, c = popt\n",
    "\n",
    "# R^2\n",
    "Ls_pred = plaw(Ds, *popt)\n",
    "Ss_res = ((Ls - Ls_pred)**2).sum()\n",
    "Ss_tot = ((Ls - Ls.mean())**2).sum()\n",
    "r2 = 1 - Ss_res / Ss_tot\n",
    "\n",
    "# Compare with theory prediction\n",
    "gamma_LN = 2.0 * np.exp((beta_LN - 0.893) / 0.425)\n",
    "beta_pred = 0.425 * np.log(gamma_LN / 2.0) + 0.893\n",
    "\n",
    "print(f\"LN Scaling Law Fit:\")\n",
    "print(f\"  β_LN = {beta_LN:.4f} (fitted), R² = {r2:.4f}\")\n",
    "print(f\"  γ_LN = {gamma_LN:.4f} (inferred from β)\")\n",
    "print(f\"  β_pred from γ_LN: {beta_pred:.4f} {'✓' if abs(beta_pred - beta_LN) < 0.01 else '✗'}\")\n",
    "print(f\"  Theory: β(γ) = 0.425·ln(γ/2.0) + 0.893\")\n",
    "print(f\"  Validation: γ_LN = {gamma_LN:.2f} < γ_c = 2.0 → sub-critical regime\")\n",
    "\n",
    "# Plot\n",
    "D_fit = np.linspace(20, 120, 200)\n",
    "plt.figure(figsize=(6,4))\n",
    "plt.scatter(Ds, Ls, s=80, zorder=5, label=\"LN data (avg over 2 seeds)\")\n",
    "plt.plot(D_fit, plaw(D_fit, *popt), 'b-', label=f\"fit: β={beta_LN:.3f}, R²={r2:.4f}\")\n",
    "plt.xscale('log'); plt.yscale('log')\n",
    "plt.xlabel(\"Width D\"); plt.ylabel(\"Val Loss\")\n",
    "plt.title(\"LN Cooling Validation (Phase B1)\")\n",
    "plt.legend(); plt.grid(True, alpha=0.3)\n",
    "plt.savefig(\"ln_scaling_law.png\", dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Plot saved: ln_scaling_law.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Step 2: J_topo Confounding Analysis (Phase B2, 10 configs)\n",
    "\n",
    "**Key question:** Does J_topo predict loss INDEPENDENTLY of width, or is it just a width proxy?\n",
    "\n",
    "Data from Phase B2 L2 top-5 (both arms):\n",
    "\n",
    "| arm | width | depth | skip | J_topo | loss |\n",
    "|------|-------|-------|------|--------|------|\n",
    "| Random | 96 | 6 | False | 0.7739 | 0.3858 |\n",
    "| Random | 64 | 5 | False | 0.8062 | 0.5014 |\n",
    "| Random | 64 | 5 | True  | 0.7838 | 0.6047 |\n",
    "| Random | 64 | 4 | False | 0.7538 | 0.6268 |\n",
    "| Random | 48 | 4 | False | 0.8027 | 0.6937 |\n",
    "| HBO    | 32 | 6 | False | 0.8627 | 0.6051 |\n",
    "| HBO    | 24 | 6 | False | 0.8774 | 0.6812 |\n",
    "| HBO    | 32 | 5 | True  | 0.8455 | 0.7479 |\n",
    "| HBO    | 24 | 6 | True  | 0.8727 | 0.7821 |\n",
    "| HBO    | 24 | 5 | True  | 0.8701 | 0.8378 |"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Phase B2 L2 data\n",
    "phase_b2 = [\n",
    "    {\"arm\": \"Random\", \"width\": 96, \"depth\": 6, \"skip\": False, \"J_topo\": 0.7739, \"loss\": 0.3858},\n",
    "    {\"arm\": \"Random\", \"width\": 64, \"depth\": 5, \"skip\": False, \"J_topo\": 0.8062, \"loss\": 0.5014},\n",
    "    {\"arm\": \"Random\", \"width\": 64, \"depth\": 5, \"skip\": True,  \"J_topo\": 0.7838, \"loss\": 0.6047},\n",
    "    {\"arm\": \"Random\", \"width\": 64, \"depth\": 4, \"skip\": False, \"J_topo\": 0.7538, \"loss\": 0.6268},\n",
    "    {\"arm\": \"Random\", \"width\": 48, \"depth\": 4, \"skip\": False, \"J_topo\": 0.8027, \"loss\": 0.6937},\n",
    "    {\"arm\": \"HBO\",    \"width\": 32, \"depth\": 6, \"skip\": False, \"J_topo\": 0.8627, \"loss\": 0.6051},\n",
    "    {\"arm\": \"HBO\",    \"width\": 24, \"depth\": 6, \"skip\": False, \"J_topo\": 0.8774, \"loss\": 0.6812},\n",
    "    {\"arm\": \"HBO\",    \"width\": 32, \"depth\": 5, \"skip\": True,  \"J_topo\": 0.8455, \"loss\": 0.7479},\n",
    "    {\"arm\": \"HBO\",    \"width\": 24, \"depth\": 6, \"skip\": True,  \"J_topo\": 0.8727, \"loss\": 0.7821},\n",
    "    {\"arm\": \"HBO\",    \"width\": 24, \"depth\": 5, \"skip\": True,  \"J_topo\": 0.8701, \"loss\": 0.8378},\n",
    "]\n",
    "\n",
    "widths  = np.array([r[\"width\"]  for r in phase_b2])\n",
    "depths  = np.array([r[\"depth\"]  for r in phase_b2])\n",
    "skips   = np.array([r[\"skip\"]   for r in phase_b2]).astype(float)\n",
    "j_topo  = np.array([r[\"J_topo\"] for r in phase_b2])\n",
    "losses  = np.array([r[\"loss\"]   for r in phase_b2])\n",
    "\n",
    "print(\"=\" * 60)\n",
    "print(\"CORRELATION ANALYSIS (Phase B2, n=10)\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "# Simple correlations\n",
    "r_JL, p_JL = spearmanr(j_topo, losses)\n",
    "r_WL, p_WL = spearmanr(widths, losses)\n",
    "r_DL, p_DL = spearmanr(depths, losses)\n",
    "r_SL, p_SL = spearmanr(skips, losses)\n",
    "r_WJ, p_WJ = spearmanr(widths, j_topo)\n",
    "\n",
    "print(f\"\\nSimple Spearman correlations with val_loss:\")\n",
    "print(f\"  J_topo → loss:  r={r_JL:+.3f}, p={p_JL:.4f}  {'***' if p_JL<.001 else '**' if p_JL<.01 else '*' if p_JL<.05 else ''}\")\n",
    "print(f\"  Width  → loss:  r={r_WL:+.3f}, p={p_WL:.4f}  {'***' if p_WL<.001 else '**' if p_WL<.01 else '*' if p_WL<.05 else ''}\")\n",
    "print(f\"  Depth  → loss:  r={r_DL:+.3f}, p={p_DL:.4f}  {'***' if p_DL<.001 else '**' if p_DL<.01 else '*' if p_DL<.05 else ''}\")\n",
    "print(f\"  Skip   → loss:  r={r_SL:+.3f}, p={p_SL:.4f}  {'***' if p_SL<.001 else '**' if p_SL<.01 else '*' if p_SL<.05 else ''}\")\n",
    "print(f\"\\nWidth vs J_topo:  r={r_WJ:+.3f}, p={p_WJ:.4f}\")\n",
    "print(f\"  → Wide networks have LOWER J_topo (confounder!)\")"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Partial correlation: J_topo → loss, controlling for width\n",
    "#\n",
    "# Method: Regress both J_topo and loss on Width, take residuals,\n",
    "# then correlate residuals.\n",
    "# If r(J_topo_resid, loss_resid) > 0, J_topo has independent signal.\n",
    "\n",
    "from sklearn.linear_model import LinearRegression\n",
    "\n",
    "def partial_correlation(x, y, z):\n",
    "    \"\"\"\n",
    "    Partial correlation r(x,y|z) via residualization.\n",
    "    Returns partial_r, p_value (approx).\n",
    "    \"\"\"\n",
    "    # Regress x on z, get residuals\n",
    "    lr_xz = LinearRegression().fit(z.reshape(-1,1), x)\n",
    "    x_resid = x - lr_xz.predict(z.reshape(-1,1))\n",
    "    # Regress y on z, get residuals\n",
    "    lr_yz = LinearRegression().fit(z.reshape(-1,1), y)\n",
    "    y_resid = y - lr_yz.predict(z.reshape(-1,1))\n",
    "    # Correlation of residuals\n",
    "    r, p = spearmanr(x_resid, y_resid)\n",
    "    return r, p, x_resid, y_resid\n",
    "\n",
    "# Partial: J_topo → loss | Width\n",
    "r_JL_W, p_JL_W, j_resid, l_resid = partial_correlation(j_topo, losses, widths)\n",
    "print(f\"\\nPartial correlation: J_topo → loss | Width\")\n",
    "print(f\"  r = {r_JL_W:+.3f}, p = {p_JL_W:.4f}\")\n",
    "if abs(r_JL_W) < 0.3:\n",
    "    print(f\"  → J_topo has WEAK independent signal beyond width\")\n",
    "elif abs(r_JL_W) < 0.6:\n",
    "    print(f\"  → J_topo has MODERATE independent signal beyond width\")\n",
    "else:\n",
    "    print(f\"  → J_topo has STRONG independent signal beyond width\")\n",
    "\n",
    "# Partial: Width → loss | J_topo\n",
    "r_WL_J, p_WL_J, w_resid, l_resid2 = partial_correlation(widths, losses, j_topo)\n",
    "print(f\"\\nPartial correlation: Width → loss | J_topo\")\n",
    "print(f\"  r = {r_WL_J:+.3f}, p = {p_WL_J:.4f}\")\n",
    "print(f\"  → Width's effect on loss after controlling for J_topo\")\n",
    "\n",
    "# Multiple regression: width + depth + skip + J_topo → loss\n",
    "print(f\"\\nMultiple regression: loss ~ width + depth + skip + J_topo\")\n",
    "X = np.column_stack([widths, depths, skips, j_topo])\n",
    "lr = LinearRegression().fit(X, losses)\n",
    "y_pred = lr.predict(X)\n",
    "r2 = 1 - ((losses - y_pred)**2).sum() / ((losses - losses.mean())**2).sum()\n",
    "print(f\"  R² = {r2:.3f}\")\n",
    "print(f\"  Coefficients (standardized):\")\n",
    "# Standardized coefficients\n",
    "X_std = (X - X.mean(axis=0)) / X.std(axis=0)\n",
    "lr_std = LinearRegression().fit(X_std, losses)\n",
    "for name, coef in zip([\"width\",\"depth\",\"skip\",\"J_topo\"], lr_std.coef_):\n",
    "    print(f\"    {name:8s}: {coef:+.3f}\")"
   ]
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "# Visualization\n",
    "fig, axes = plt.subplots(1, 3, figsize=(14, 4))\n",
