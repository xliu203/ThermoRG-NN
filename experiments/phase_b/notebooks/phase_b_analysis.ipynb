    "# Panel 1: J_topo vs loss (color by width)\n",
    "ax = axes[0]\n",
    "sc = ax.scatter(j_topo, losses, c=widths, cmap='viridis', s=80, zorder=5)\n",
    "ax.set_xlabel(\"J_topo\"); ax.set_ylabel(\"Val Loss\")\n",
    "ax.set_title(f\"J_topo vs Loss\\nSpearman r={r_JL:+.3f} (p={p_JL:.3f})\")\n",
    "plt.colorbar(sc, ax=ax, label=\"Width\")\n",
