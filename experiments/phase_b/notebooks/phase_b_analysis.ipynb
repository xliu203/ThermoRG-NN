    "    print(f\"  → J_topo is NOT purely a width proxy; it carries independent signal.\")\n",
    "else:\n",
    "    print(f\"  J_topo's correlation with loss is largely explained by width.\")\n",
    "    print(f\"  → J_topo may be a proxy for width rather than an independent topological metric.\")\n",
    "\n",
    "# NOTE: With n=10, this analysis has LOW STATISTICAL POWER.\n",
    "# The partial correlation is indicative but not conclusive.\n",
    "print(f\"\\n⚠️  Caveat: n=10 is small. These results are indicative, not conclusive.\")\n",
    "print(f\"    A proper partial correlation study requires n≥30 for reliable inference.\")"
   ]
