    "ax = axes[1]\n",
    "sc = ax.scatter(widths, losses, c=j_topo, cmap='plasma', s=80, zorder=5)\n",
    "ax.set_xlabel(\"Width\"); ax.set_ylabel(\"Val Loss\")\n",
    "ax.set_title(f\"Width vs Loss\\nSpearman r={r_WL:+.3f} (p={p_WL:.3f})\")\n",
    "plt.colorbar(sc, ax=ax, label=\"J_topo\")\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "# Panel 3: Width vs J_topo (confounder)\n",
    "ax = axes[2]\n",
    "sc = ax.scatter(widths, j_topo, c=losses, cmap='RdYlGn_r', s=80, zorder=5)\n",
    "ax.set_xlabel(\"Width\"); ax.set_ylabel(\"J_topo\")\n",
    "ax.set_title(f\"Width vs J_topo (Confounder)\\nSpearman r={r_WJ:+.3f}\")\n",
    "plt.colorbar(sc, ax=ax, label=\"Loss\")\n",
    "ax.grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(\"confounding_analysis.png\", dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Plot saved: confounding_analysis.png\")"
   ]
  },
