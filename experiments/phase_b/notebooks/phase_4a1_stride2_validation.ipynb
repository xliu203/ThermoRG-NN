  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3: J_topo Computation (with Stride/MaxPool Correction)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def compute_D_eff(W):\n",
    "    \"\"\"D_eff = ||W||_F² / ||W||_2²\"\"\"\n",
    "    if W.dim() == 4:\n",
    "        W = W.view(W.size(0), -1)\n",
    "    fro_sq = (W ** 2).sum().item()\n",
    "    S = linalg.svd(W.cpu()).S\n",
    "    spec_sq = S[0].item() ** 2 + 1e-12\n",
    "    return fro_sq / spec_sq\n",
    "\n",
    "def compute_J_topo_stride(model, d_input=3.0):\n",
    "    \"\"\"\n",
    "    J_topo with stride-2 and max-pool RG correction.\n",
    "    \n",
    "    For Conv2d stride s > 1: ζ = C_out / (C_in · s²)\n",
    "    For MaxPool2d: ζ = 1 / s² = 1/4\n",
    "    \"\"\"\n",
    "    skip_exclude = ['layernorm', 'layer_norm', 'norm', 'batchnorm', \n",
    "                    'bn', 'flatten', 'fc', 'linear']\n",
    "    \n",
    "    eta_list = []\n",
    "    prev_D_eff = None\n",
    "    prev_c_out = None\n",
    "    \n",
    "    for name, module in model.named_modules():\n",
    "        if any(p in name.lower() for p in skip_exclude):\n",
    "            continue\n",
    "        \n",
    "        if isinstance(module, nn.Conv2d):\n",
    "            W = module.weight.data\n",
    "            s = module.stride[0] if hasattr(module, 'stride') else 1\n",
    "            c_in = module.in_channels\n",
    "            c_out = module.out_channels\n",
    "            \n",
    "            D_eff = compute_D_eff(W)\n",
    "            \n",
    "            if prev_D_eff is not None and prev_c_out is not None:\n",
    "                eta = D_eff / max(prev_D_eff, 1.0)\n",
    "                if s > 1:\n",
    "                    zeta = (c_out / prev_c_out) / (s ** 2)\n",
    "                    eta = eta * zeta\n",
    "                eta_list.append(float(eta))\n",
    "            \n",
    "            prev_D_eff = D_eff\n",
    "            prev_c_out = c_out\n",
    "        \n",
    "        elif isinstance(module, nn.MaxPool2d):\n",
    "            s = module.stride if hasattr(module, 'stride') else 2\n",
    "            if s > 1:\n",
    "                zeta = 1.0 / (s ** 2)\n",
    "                if prev_D_eff is not None:\n",
    "                    eta = zeta\n",
    "                    eta_list.append(float(eta))\n",
    "    \n",
    "    if not eta_list:\n",
    "        return 1.0, []\n",
    "    \n",
    "    log_etas = [abs(math.log(max(e, 1e-10))) for e in eta_list]\n",
    "    J_topo = math.exp(-np.mean(log_etas))\n",
    "    return float(J_topo), eta_list\n",
    "\n",
    "def count_downsampling_layers(model):\n",
    "    n_stride2_conv = 0\n",
    "    n_maxpool = 0\n",
    "    for module in model.modules():\n",
    "        if isinstance(module, nn.Conv2d):\n",
    "            if module.stride[0] == 2:\n",
    "                n_stride2_conv += 1\n",
    "        elif isinstance(module, nn.MaxPool2d):\n",
    "            if hasattr(module, 'stride') and module.stride == 2:\n",
    "                n_maxpool += 1\n",
    "            elif not hasattr(module, 'stride'):\n",
    "                n_maxpool += 1\n",
    "    return n_stride2_conv, n_maxpool"
   ]
  },
