   "source": [
    "## Step 5: Compute Theory Predictions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"\\n--- Theoretical β predictions ---\")\n",
    "print(\"Using: β = β₀ · 0.87^n_s,  β₀ ≈ 0.86 (calibrated from Phase A)\")\n",
    "print()\n",
    "\n",
    "beta0 = 0.86\n",
    "phi = 0.87\n",
    "\n",
    "predictions = {}\n",
    "for name, (atype, arch) in ARCHITECTURES.items():\n",
    "    arch.eval()\n",
    "    J, _ = compute_J_topo_stride(arch)\n",
    "    n_s_conv, n_s_mp = count_downsampling_layers(arch)\n",
    "    n_s = n_s_conv + n_s_mp\n",
    "    \n",
    "    beta_pred = beta0 * (phi ** n_s)\n",
    "    \n",
    "    predictions[name] = {\n",
    "        'type': atype,\n",
    "        'n_s': n_s,\n",
    "        'J_topo': J,\n",
    "        'beta_pred': beta_pred,\n",
    "        'n_s_conv': n_s_conv,\n",
    "        'n_s_mp': n_s_mp\n",
    "    }\n",
    "    print(f\"{name:<20}: n_s={n_s}, J_topo={J:.4f}, β_pred={beta_pred:.4f}\")\n",
    "\n",
    "print(\"\\nNote: ThermoNet-MP-2 and ThermoNet-S2-2 both have n_s=2\")\n",
    "print(\"      but MP has ζ=0.25 (spatial only) vs S2 has ζ~0.5 (spatial+channel)\")\n",
    "print(\"      Theory predicts: J_topo(MP) < J_topo(S2) but same β suppression\")"
   ]
  },
