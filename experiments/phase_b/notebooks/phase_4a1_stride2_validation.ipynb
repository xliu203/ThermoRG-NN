   "source": [
    "## Step 4: Define Architecture Variants"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ThermoNetL3(nn.Module):\n",
    "    \"\"\"Baseline: 3-layer ConvNet, no downsampling (n_s=0)\"\"\"\n",
    "    def __init__(self, base_ch=64):\n",
    "        super().__init__()\n",
    "        self.blocks = nn.ModuleList([\n",
    "            nn.Conv2d(3, base_ch, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(base_ch),\n",
    "            nn.GELU(),\n",
    "            nn.Conv2d(base_ch, base_ch*2, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(base_ch*2),\n",
    "            nn.GELU(),\n",
    "            nn.Conv2d(base_ch*2, base_ch*2, 3, padding=1, bias=False),\n",
    "            nn.BatchNorm2d(base_ch*2),\n",
    "            nn.GELU(),\n",
    "        ])\n",
    "        self.pool = nn.AdaptiveAvgPool2d((1,1))\n",
    "        self.fc = nn.Linear(base_ch*2, 10)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        for b in self.blocks:\n",
    "            x = b(x)\n",
    "        x = self.pool(x)\n",
    "        x = x.view(x.size(0), -1)\n",
    "        return self.fc(x)\n",
    "\n",
    "\n",
    "class ThermoNetS2_1(nn.Module):\n",
    "    \"\"\"1 stride-2 conv after layer 1 (n_s=1)\"\"\"\n",
    "    def __init__(self, base_ch=64):\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Conv2d(3, base_ch, 3, padding=1, bias=False)\n",
    "        self.bn1 = nn.BatchNorm2d(base_ch)\n",
    "        self.act1 = nn.GELU()\n",
    "        self.down1 = nn.Conv2d(base_ch, base_ch*2, 3, stride=2, padding=1, bias=False)\n",
    "        self.bn_down1 = nn.BatchNorm2d(base_ch*2)\n",
    "        self.act_down1 = nn.GELU()\n",
    "        self.conv2 = nn.Conv2d(base_ch*2, base_ch*2, 3, padding=1, bias=False)\n",
    "        self.bn2 = nn.BatchNorm2d(base_ch*2)\n",
    "        self.act2 = nn.GELU()\n",
    "        self.pool = nn.AdaptiveAvgPool2d((1,1))\n",
    "        self.fc = nn.Linear(base_ch*2, 10)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x = self.act1(self.bn1(self.conv1(x)))\n",
    "        x = self.act_down1(self.bn_down1(self.down1(x)))\n",
    "        x = self.act2(self.bn2(self.conv2(x)))\n",
    "        x = self.pool(x)\n",
    "        x = x.view(x.size(0), -1)\n",
    "        return self.fc(x)\n",
    "\n",
    "\n",
    "class ThermoNetS2_2(nn.Module):\n",
    "    \"\"\"2 stride-2 convs (n_s=2)\"\"\"\n",
    "    def __init__(self, base_ch=64):\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Conv2d(3, base_ch, 3, padding=1, bias=False)\n",
    "        self.bn1 = nn.BatchNorm2d(base_ch)\n",
    "        self.act1 = nn.GELU()\n",
    "        self.down1 = nn.Conv2d(base_ch, base_ch*2, 3, stride=2, padding=1, bias=False)\n",
    "        self.bn_down1 = nn.BatchNorm2d(base_ch*2)\n",
    "        self.act_down1 = nn.GELU()\n",
    "        self.conv2 = nn.Conv2d(base_ch*2, base_ch*2, 3, padding=1, bias=False)\n",
    "        self.bn2 = nn.BatchNorm2d(base_ch*2)\n",
    "        self.act2 = nn.GELU()\n",
    "        self.down2 = nn.Conv2d(base_ch*2, base_ch*4, 3, stride=2, padding=1, bias=False)\n",
    "        self.bn_down2 = nn.BatchNorm2d(base_ch*4)\n",
    "        self.act_down2 = nn.GELU()\n",
    "        self.conv3 = nn.Conv2d(base_ch*4, base_ch*4, 3, padding=1, bias=False)\n",
    "        self.bn3 = nn.BatchNorm2d(base_ch*4)\n",
    "        self.act3 = nn.GELU()\n",
    "        self.pool = nn.AdaptiveAvgPool2d((1,1))\n",
    "        self.fc = nn.Linear(base_ch*4, 10)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x = self.act1(self.bn1(self.conv1(x)))\n",
    "        x = self.act_down1(self.bn_down1(self.down1(x)))\n",
    "        x = self.act2(self.bn2(self.conv2(x)))\n",
    "        x = self.act_down2(self.bn_down2(self.down2(x)))\n",
    "        x = self.act3(self.bn3(self.conv3(x)))\n",
    "        x = self.pool(x)\n",
    "        x = x.view(x.size(0), -1)\n",
    "        return self.fc(x)\n",
    "\n",
    "\n",
    "class ThermoNetMP_2(nn.Module):\n",
    "    \"\"\"2 max-poolings (对比stride-2, n_s=2)\"\"\"\n",
    "    def __init__(self, base_ch=64):\n",
    "        super().__init__()\n",
    "        self.conv1 = nn.Conv2d(3, base_ch, 3, padding=1, bias=False)\n",
    "        self.bn1 = nn.BatchNorm2d(base_ch)\n",
    "        self.act1 = nn.GELU()\n",
    "        self.pool1 = nn.MaxPool2d(2)\n",
    "        self.conv2 = nn.Conv2d(base_ch, base_ch*2, 3, padding=1, bias=False)\n",
    "        self.bn2 = nn.BatchNorm2d(base_ch*2)\n",
    "        self.act2 = nn.GELU()\n",
    "        self.pool2 = nn.MaxPool2d(2)\n",
    "        self.conv3 = nn.Conv2d(base_ch*2, base_ch*4, 3, padding=1, bias=False)\n",
    "        self.bn3 = nn.BatchNorm2d(base_ch*4)\n",
    "        self.act3 = nn.GELU()\n",
    "        self.pool = nn.AdaptiveAvgPool2d((1,1))\n",
    "        self.fc = nn.Linear(base_ch*4, 10)\n",
    "    \n",
    "    def forward(self, x):\n",
    "        x = self.act1(self.bn1(self.conv1(x)))\n",
    "        x = self.pool1(x)\n",
    "        x = self.act2(self.bn2(self.conv2(x)))\n",
    "        x = self.pool2(x)\n",
    "        x = self.act3(self.bn3(self.conv3(x)))\n",
    "        x = self.pool(x)\n",
    "        x = x.view(x.size(0), -1)\n",
    "        return self.fc(x)\n",
    "\n",
    "\n",
    "from experiments.lift_test import ResNet18CIFAR\n",
    "\n",
    "ARCHITECTURES = {\n",
    "    'ThermoNet-L3':  ('baseline',      ThermoNetL3(base_ch=64)),\n",
    "    'ThermoNet-S2-1': ('stride2',     ThermoNetS2_1(base_ch=64)),\n",
    "    'ThermoNet-S2-2': ('stride2',     ThermoNetS2_2(base_ch=64)),\n",
    "    'ThermoNet-MP-2': ('maxpool',     ThermoNetMP_2(base_ch=64)),\n",
    "    'ResNet-18':      ('stride2',     ResNet18CIFAR()),\n",
    "}\n",
    "\n",
    "print(\"Architecture summary:\")\n",
    "print(f\"{'Name':<20} {'Type':<10} {'n_s':<5} {'J_topo':<10} {'Params(M)'}\")\n",
    "print(\"-\"*60)\n",
    "for name, (atype, arch) in ARCHITECTURES.items():\n",
    "    arch.eval()\n",
    "    J, _ = compute_J_topo_stride(arch)\n",
    "    n_s_conv, n_s_mp = count_downsampling_layers(arch)\n",
    "    n_s = n_s_conv + n_s_mp\n",
    "    n_params = sum(p.numel() for p in arch.parameters()) / 1e6\n",
    "    print(f\"{name:<20} {atype:<10} {n_s:<5} {J:<10.4f} {n_params:.2f}\")"
   ]
  },
