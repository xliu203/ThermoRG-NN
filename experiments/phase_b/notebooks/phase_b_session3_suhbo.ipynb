   "source": [
    "import pandas as pd\n",
    "\n",
    "# Create results dataframe\n",
    "df = pd.DataFrame([{\n",
    "    'Architecture': r['config'].name,\n",
    "    'Loss (5ep)': r['loss'],\n",
    "    'Utility': r['utility'],\n",
    "    'J_topo': r['j_topo'],\n",
    "    'gamma_est': r['gamma_est']\n",
    "} for r in results])\n",
    "\n",
    "# Rank by utility\n",
    "df['Utility_Rank'] = df['Utility'].rank(ascending=False)\n",
    "# Rank by loss\n",
    "df['Loss_Rank'] = df['Loss (5ep)'].rank(ascending=True)\n",
    "\n",
    "df = df.sort_values('Utility_Rank')\n",
    "\n",
    "print(\"Architecture Ranking:\")\n",
    "print(df.to_string(index=False))\n",
    "\n",
    "# Best architecture\n",
    "best = df.iloc[0]\n",
    "print(f\"\\n{'='*60}\")\n",
    "print(f\"BEST ARCHITECTURE: {best['Architecture']}\")\n",
    "print(f\"  Utility: {best['Utility']:.4f}\")\n",
    "print(f\"  Loss (5ep): {best['Loss (5ep)']:.4f}\")\n",
    "print(f\"  J_topo: {best['J_topo']:.4f}\")\n",
    "print(f\"{'='*60}\")"
   ]
