    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(WORK_DIR, 'exponent_b_vs_epoch.png'), dpi=150, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"Saved: exponent_b_vs_epoch.png\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "plot_lambda_max_raw",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Plot 2: λ_max vs Width at Different Epochs ──────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "\n",
    "colors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd']\n",
