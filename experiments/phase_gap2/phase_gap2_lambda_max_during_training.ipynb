    "\n",
    "ax.set_xlabel('Epoch')\n",
    "ax.set_ylabel('Exponent b')\n",
    "ax.set_title('λ_max Scaling Exponent b vs Training Epoch')\n",
    "ax.set_xlim(-5, 105)\n",
    "ax.set_ylim(0, 0.7)\n",
    "ax.legend()\n",
    "ax.grid(True, alpha=0.3)\n",
