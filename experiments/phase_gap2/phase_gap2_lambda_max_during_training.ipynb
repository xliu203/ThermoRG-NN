  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "plot_log_log",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Plot 3: log-log λ_max vs D with fits ───────────────────────────────────\n",
    "fig, ax = plt.subplots(figsize=(7, 5))\n",
    "\n",
    "log_D = np.log(D_vals)\n",
